# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False

# One Gmail/Google Workspace mailbox used for both SMTP and IMAP.
# Use a Google App Password, never the normal account password.
EMAIL_HOST_USER=civilai@example.com
EMAIL_HOST_PASSWORD=replace-with-google-app-password

# Optional inbound-mail safety limits
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_LOOKBACK_DAYS=5
EMAIL_IMAP_MAX_MESSAGES=50
EMAIL_IMAP_MAX_ATTACHMENT_MB=15
EMAIL_IMAP_COOLDOWN_SECONDS=60
EMAIL_IMAP_API_RATE=40/hour
EMAIL_IMAP_SYNC_INTERVAL_SECONDS=120
EMAIL_SEND_API_RATE=10/hour

# Caps each cloud-LLM answer to control usage/cost.
RAG_MAX_OUTPUT_TOKENS=600
